# ── Anthropic ────────────────────────────────────────────────────
# Obtené tu key en: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# ── Twilio (WhatsApp Bot) ─────────────────────────────────────────
# Obtené en: https://console.twilio.com
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_WHATSAPP_FROM=+14155238886   # número de Twilio (sandbox: +14155238886)

# Tu número de WhatsApp con código de país (sin +, sin espacios)
WHATSAPP_MY_NUMBER=+549...

# ── Trello (opcional, para briefings automáticos de WhatsApp) ─────
# API Key: https://trello.com/app-key
# Token: generá uno en la misma página
TRELLO_API_KEY=
TRELLO_TOKEN=
TRELLO_BOARD_ID=   # ID del tablero principal de la agencia

# ── Server ────────────────────────────────────────────────────────
PORT=3000
